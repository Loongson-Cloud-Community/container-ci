{% include 'partials/license.j2' %}

FROM {{ base_image }}

{% include 'partials/nix-env.j2' %}

# 尝试更新源，若失败则切换到国内源重试
RUN apk update || \
    (sed -i 's/dl-cdn.alpinelinux.org/mirrors.ustc.edu.cn/g' /etc/apk/repositories && apk update)

RUN apk add --no-cache \
        ca-certificates \
        tzdata \
        musl-locales musl-locales-lang \
        {% if image_type == "jdk" %}
        openjdk{{ version }}-jdk
        {% else %}
        openjdk{{ version }}-jre
        {% endif %}

ENV JAVA_HOME=/usr/lib/jvm/java-{{ version }}-openjdk
ENV PATH=$JAVA_HOME/bin:$PATH

{% include 'partials/version-check.j2' %}
{% include 'partials/entrypoint.j2' %}
{% include 'partials/jshell.j2' %}
